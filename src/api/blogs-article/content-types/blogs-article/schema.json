{
  "kind": "collectionType",
  "collectionName": "blogs_articles",
  "info": {
    "singularName": "blogs-article",
    "pluralName": "blogs-articles",
    "displayName": "blogs article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "Title"
    },
    "Tags": {
      "type": "component",
      "component": "shared.blog-tag",
      "repeatable": true
    },
    "BlogSections": {
      "type": "dynamiczone",
      "components": [
        "components.blog-hero",
        "components.blog-content",
        "components.content-list",
        "shared.code-block"
      ]
    },
    "DescriptionProyect": {
      "type": "text"
    },
    "ImgPreview": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    }
  }
}
